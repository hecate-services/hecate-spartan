%% -*- mode: erlang -*-
%% rebar3 configuration for hecate_spartan
%%
%% Layer-2 hecate-om service: the federated mesh commons for Spartan
%% autonomous agents. Owns a reckon-db event store (message routing +
%% entity registry provenance), so it links reckon_db/evoq transitively
%% through hecate_om.

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    %% The shared L2 substrate. Brings macula (mesh SDK), cowboy/jsx
    %% (health endpoint), and the reckon_db/evoq/reckon_evoq stack that
    %% hecate_om:boot/1 wires when a service exports store_id/0 + data_dir/0.
    {hecate_om, "~> 0.6"}
]}.

{project_plugins, [rebar3_ex_doc, rebar3_lint]}.

%% Elvis: the org's structural ruleset — no deep nesting (HARD, one level), no
%% nested try/catch, no if-expression. Run via `rebar3 lint`.
{elvis, [
    {rulesets, #{
        macula_min => [
            {elvis_style, no_deep_nesting, #{level => 2}},
            {elvis_style, no_nested_try_catch, #{}},
            {elvis_style, no_if_expression, #{}}
        ]
    }},
    {config, [#{files => ["apps/*/src/**/*.erl"], ruleset => macula_min}]}
]}.

{relx, [
    {release, {hecate_spartan, "0.1.0"}, [hecate_spartan, sasl]},
    {sys_config_src, "config/sys.config.src"},
    {vm_args_src,    "config/vm.args.src"},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [{relx, [{mode, prod},
                    {include_src, false},
                    {include_erts, true},
                    {debug_info, strip}]}]}
]}.

%% Same rationale as hecate_om: the macula + reckon-db stacks ship to hex
%% without debug_info (NIF-heavy), so dialyzer can't read their Core Erlang.
%% Exclude them from the PLT; keep the well-behaved deps analysable.
{dialyzer, [
    {warnings, [no_unknown]},
    {exclude_apps, [
        macula, macula_envy, macula_mdns,
        reckon_db, reckon_evoq, reckon_gater, evoq,
        khepri, ra, horus, aten, seshat, gen_batch_server,
        gproc, msgpack, cowboy, ranch, jsx
    ]}
]}.

{shell, [{apps, [hecate_spartan]}]}.

{ex_doc, [
    {source_url, <<"https://codeberg.org/hecate-services/hecate-spartan">>},
    {extras, ["README.md", "CHANGELOG.md", "LICENSE",
              "specs/SPEC_HECATE_SPARTAN.md",
              "plans/PLAN_HECATE_SPARTAN.md",
              "guides/architecture.md"]},
    {main, "README.md"}
]}.
